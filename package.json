{
  "name": "@alternative-design-and-media/quick-api-connector",
  "version": "0.1.0",
  "description": "Type-safe quick API connector for Node.js and edge runtimes.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "api",
    "connector",
    "typescript"
  ],
  "author": "Alternative Design and Media",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alternative-Design-And-Media/quick-api-connector.git"
  },
  "bugs": {
    "url": "https://github.com/Alternative-Design-And-Media/quick-api-connector/issues"
  },
  "homepage": "https://github.com/Alternative-Design-And-Media/quick-api-connector#readme",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
